{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/login", "dest": "/api/login.js" },
    { "src": "/api/hubspot", "dest": "/api/hubspot.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
